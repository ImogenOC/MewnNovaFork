"huW" = (/obj/structure/table/reinforced/plastitaniumglass,/obj/item/permanent_portal_creator{pixel_x = 2; pixel_y = 9},/obj/item/permanent_portal_anchor{pixel_x = 4; pixel_y = -1; layer = 4; plane = -3},/obj/item/paper{pixel_x = -9; pixel_y = 0; default_raw_text = "<table border=2 width=380 cellpadding=6 bgcolor=#ffffff><tr><td><center><b>NANOTRASEN TECHNICAL REFERENCE</b></center><center><b>Permanent Portal Deployment Guide</b></center><table width=100% border=1 cellspacing=0 cellpadding=4><tr>    <td colspan=2>        <center><b>Experimental Spatial Technology</b></center>        <center>Internal Use Only</center>    </td></tr><tr>    <td colspan=2>        <table width="100%" height="4" cellpadding="0" cellspacing="0" border="0" bgcolor="#374f7e">            <tr><td></td></tr>        </table>    </td></tr><tr>    <td colspan=2><b>Purpose</b></td></tr><tr>    <td colspan=2>        This procedure details the creation of <b>stationary, permanent portals</b>        allowing instant travel between two fixed locations.    </td></tr><tr>    <td colspan=2><b>Required Equipment</b></td></tr><tr>    <td colspan=2>        • ITEM/permanent_portal_anchor<br>        • ITEM/permanent_portal_creator    </td></tr><tr>    <td colspan=2><b>Deployment Procedure</b></td></tr><tr>    <td colspan=2>        1. Spawn into the Thunderdome.        2 Spawn the following items        • permanent_portal_anchor        • permanent_portal_creator        3.Hold the beacon-shaped device (portal anchor) in hand and        wait for the progress bar to complete        4. Strike the beacon using the <b>hand-teleporter device.        5. Use the hand-teleporter in place to finalize the link.        6. Two permanent portals will now exist.   </tr><tr>    <td colspan=2><b>Relocation Notes</b></td></tr><tr>    <td colspan=2>        The portals may be moved to any desired location using standard        object relocation techniques, including but not limited to:<br><br>        • VV → Get Moveable        • Reverse Supply Pods        • Possess Object   </tr><tr>    <td colspan=2>        <center><b>END OF DOCUMENT</b></center>    </td></tr></table></td></tr></table>"},/turf/open/floor/mineral/plastitanium,/area{name = "CentCom Administrative Satellite"; icon_state = "party"; default_gravity = 1})
